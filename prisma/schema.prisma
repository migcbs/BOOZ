generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum Role {
  cliente
  coach
  admin
}

enum TipoSuscripcion {
  REGULAR
  SUSCRIPTO
}

enum TipoPaquete {
  LMV
  MJ
  SUELTA
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  password            String?
  role                String          @default("cliente")

  // --- Información Personal ---
  nombre              String
  apellido            String
  telefono            String?
  fechaNacimiento     DateTime?
  contactoEmergencia  String?
  profileImageUrl     String?         @db.Text
  instagram           String?

  // --- Información Médica ---
  tipoSangre          String?
  alergias            String?
  lesiones            String?         @db.Text

  // --- Lógica de Negocio ---
  tipoCliente         TipoSuscripcion @default(REGULAR)
  creditosDisponibles Int             @default(0)
  suscripcionActiva   Boolean         @default(false)
  planNombre          String?
  paqueteTipo         TipoPaquete?
  vencimientoPlan     DateTime?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relaciones
  reservas            Class[]         @relation("UserReservas")
  listaEspera         WaitingList[]
}

model Class {
  id            String      @id @default(uuid())
  nombre        String      
  tematica      String?     
  descripcion   String?     @db.Text
  paqueteRef    TipoPaquete @default(SUELTA)
  
  fecha         DateTime    
  color         String?     @default("#89CFF0")
  imageUrl      String?     @db.Text
  
  // Lógica de Capacidad
  cupoMaximo    Int         @default(8)
  inscritos     Int         @default(0)
  numeroCamilla Int?        // Específico para reservas individuales
  
  // Relación con el Cliente (Cuando la clase ya es una reserva individual)
  userId        String?
  user          User?       @relation("UserReservas", fields: [userId], references: [id])

  // Relación con Lista de Espera
  espera        WaitingList[]

  createdAt     DateTime    @default(now())
  @@index([fecha])
}

model WaitingList {
  id        String   @id @default(uuid())
  claseId   String
  userId    String
  clase     Class    @relation(fields: [claseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prioridad Int      @default(1) // Por si quieres manejar prioridades VIP
  createdAt DateTime @default(now())

  @@unique([claseId, userId]) // Evita que un usuario se anote dos veces a la misma lista
}