generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// ✅ CORRECCIÓN: Enums bien definidos y usados en los campos correspondientes
enum Role {
  cliente
  coach
  admin
}

enum TipoSuscripcion {
  REGULAR
  SUSCRIPTO
}

enum TipoPaquete {
  LMV
  MJ
  SUELTA
}

enum MetodoPago {
  CREDITOS
  SUSCRIPCION
  CORTESIA  // Para asignaciones manuales de admin/coach
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  password            String?

  // ✅ CORRECCIÓN: role usa el enum Role, no String
  role                Role            @default(cliente)

  // --- Información Personal ---
  nombre              String
  apellido            String
  telefono            String?
  fechaNacimiento     DateTime?
  contactoEmergencia  String?
  profileImageUrl     String?         @db.Text
  instagram           String?

  // --- Información Médica ---
  tipoSangre          String?
  alergias            String?
  lesiones            String?         @db.Text

  // --- Lógica de Negocio ---
  tipoCliente         TipoSuscripcion @default(REGULAR)
  creditosDisponibles Int             @default(0)
  suscripcionActiva   Boolean         @default(false)
  planNombre          String?
  paqueteTipo         TipoPaquete?
  vencimientoPlan     DateTime?

  // ✅ NUEVO: Referencia al último pago Stripe para auditoría
  ultimoPagoStripeId  String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relaciones
  reservas            Class[]         @relation("UserReservas")
  listaEspera         WaitingList[]
}

model Class {
  id            String      @id @default(uuid())
  nombre        String
  tematica      String?
  descripcion   String?     @db.Text
  paqueteRef    TipoPaquete @default(SUELTA)

  fecha         DateTime
  color         String?     @default("#89CFF0")
  imageUrl      String?     @db.Text

  // Lógica de Capacidad
  cupoMaximo    Int         @default(8)
  inscritos     Int         @default(0)
  numeroCamilla Int?

  // ✅ NUEVO: Guardamos cómo se pagó esta reserva para
  // devolver crédito correctamente al cancelar
  metodoPago    MetodoPago?

  // Relación con el Cliente (null = clase maestra/plantilla, con userId = reserva individual)
  userId        String?
  user          User?       @relation("UserReservas", fields: [userId], references: [id])

  // Relación con Lista de Espera
  espera        WaitingList[]

  createdAt     DateTime    @default(now())

  @@index([fecha])
  @@index([userId])          // ✅ NUEVO: índice para consultas de reservas por usuario
  @@index([paqueteRef])      // ✅ NUEVO: índice para filtros por tipo de clase
}

model WaitingList {
  id        String   @id @default(uuid())
  claseId   String
  userId    String
  clase     Class    @relation(fields: [claseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prioridad Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([claseId, userId])
  @@index([claseId, createdAt]) // ✅ NUEVO: para obtener el primero en espera eficientemente
}

// ✅ NUEVO: Tabla para idempotencia de webhooks de Stripe
// Evita que un mismo evento se procese dos veces si Stripe reintenta
model ProcessedStripeEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String   // payment_intent.succeeded, checkout.session.completed, etc.
  processedAt   DateTime @default(now())

  @@index([stripeEventId])
}
